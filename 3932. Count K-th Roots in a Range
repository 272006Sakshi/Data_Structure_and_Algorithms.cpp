class Solution {
public:
    int countKthRoots(int l, int r, int k) {
        int count=0;
        if(k==1) return r-l+1;

        int x = pow(r, (double)1/k);
        for(int i=0;i<=x+1;i++){
            long long val = pow(i, k);
            if(val>=l && val<=r) count++;
        }
        return count;
    }
};
